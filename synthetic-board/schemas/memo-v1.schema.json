{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sboard.local/schemas/memo.schema.json",
  "title": "BoardMemo",
  "description": "The one-page signed board memo. The product of a meeting. Immutable once written.",
  "type": "object",
  "required": [
    "memo_id",
    "petition_id",
    "meeting_type",
    "protocol_version",
    "created_at",
    "source",
    "verdict",
    "confidence_weighted",
    "confidence_spread",
    "verdict_reasoning",
    "dissent_summary",
    "dissent_source",
    "kill_criteria",
    "next_action",
    "signatures",
    "metadata"
  ],
  "properties": {

    "memo_id": {
      "type": "string",
      "format": "uuid"
    },
    "petition_id": {
      "type": "string",
      "format": "uuid"
    },
    "meeting_type": {
      "type": "string",
      "enum": ["idea_screen"]
    },
    "protocol_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": ["board", "baseline"],
      "description": "Whether this memo came from the synthetic board or a single-LLM baseline. Used by the A/B harness."
    },

    "verdict": {
      "type": "string",
      "enum": ["proceed", "kill", "conditional"]
    },
    "confidence_weighted": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 3.0,
      "description": "Sum of recalibrated confidence across seats voting the winning verdict. Max is roughly n_seats."
    },
    "confidence_spread": {
      "type": "number",
      "minimum": 0.0,
      "description": "Difference between winning score and runner-up score. Higher = more decisive."
    },

    "verdict_reasoning": {
      "type": "string",
      "minLength": 50,
      "maxLength": 1500,
      "description": "The case for the winning verdict as it stands at the end of the meeting. ≤200 words target."
    },
    "dissent_summary": {
      "type": "string",
      "minLength": 50,
      "maxLength": 1200,
      "description": "The minority's strongest case, charitably stated. ≤150 words target. Never empty."
    },
    "dissent_source": {
      "type": "string",
      "description": "seat_id of the dissenting seat (or the forced-dissent author in unanimous cases)."
    },

    "kill_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["criterion", "owner_to_monitor"],
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 20,
            "maxLength": 300,
            "description": "A falsifiable, measurable, time-bounded condition that would flip the verdict."
          },
          "owner_to_monitor": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "Role or person responsible for tracking this criterion."
          }
        },
        "additionalProperties": false
      }
    },

    "next_action": {
      "type": "object",
      "required": ["action", "owner", "deadline"],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200,
          "description": "Imperative voice. One step, not a plan."
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "deadline": {
          "type": "string",
          "format": "date"
        }
      },
      "additionalProperties": false
    },

    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["seat_id", "verdict", "confidence_raw", "confidence_recalibrated"],
        "properties": {
          "seat_id": { "type": "string" },
          "verdict": { "enum": ["proceed", "kill", "conditional"] },
          "confidence_raw": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "confidence_recalibrated": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.5
          }
        },
        "additionalProperties": false
      }
    },

    "metadata": {
      "type": "object",
      "required": [
        "persona_hashes",
        "model_ids",
        "seed",
        "wall_clock_seconds",
        "llm_cost_usd",
        "unanimous",
        "forced_dissent_triggered"
      ],
      "properties": {
        "persona_hashes": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "seat_id -> SHA-256 hash of the persona file. Empty for baseline memos."
        },
        "model_ids": {
          "type": "object",
          "required": ["seats", "synthesis"],
          "properties": {
            "seats": { "type": "string" },
            "synthesis": { "type": "string" }
          }
        },
        "seed": { "type": "integer" },
        "wall_clock_seconds": {
          "type": "number",
          "minimum": 0.0
        },
        "llm_cost_usd": {
          "type": "number",
          "minimum": 0.0
        },
        "unanimous": { "type": "boolean" },
        "forced_dissent_triggered": { "type": "boolean" },
        "references_memo_id": {
          "type": ["string", "null"],
          "format": "uuid",
          "description": "If this memo chains to a prior one (e.g., Post-Mortem to Idea Screen). MVP: null."
        },
        "reasoning_overlap_score": {
          "type": ["number", "null"],
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Jaccard similarity over key terms from each seat's top_three_reasons. >0.6 flags theatrical consensus."
        }
      }
    }
  },
  "additionalProperties": false
}
