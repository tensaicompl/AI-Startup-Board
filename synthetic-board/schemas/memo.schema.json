{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sboard.local/schemas/memo.schema.json",
  "title": "BoardMemoV2",
  "description": "The v2 board memo: seven-seat deliberation, five-stage body. Default schema. Immutable once written. v1 memos are preserved at memo-v1.schema.json.",
  "type": "object",
  "required": [
    "schema_version",
    "memo_id",
    "petition_id",
    "meeting_type",
    "protocol_version",
    "created_at",
    "source",
    "verdict",
    "confidence_weighted",
    "confidence_spread",
    "idea_analysis",
    "verdict_reasoning",
    "vision",
    "dissent_summary",
    "dissent_source",
    "kill_criteria",
    "next_action",
    "signatures",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0",
      "description": "Memo schema version discriminator. v2 = five-stage body, seven seats."
    },
    "memo_id": { "type": "string", "format": "uuid" },
    "petition_id": { "type": "string", "format": "uuid" },
    "meeting_type": { "type": "string", "enum": ["idea_screen"] },
    "protocol_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "created_at": { "type": "string", "format": "date-time" },
    "source": {
      "type": "string",
      "enum": ["board", "baseline"],
      "description": "Synthetic board vs single-LLM baseline. Used by the A/B harness."
    },

    "verdict": { "type": "string", "enum": ["proceed", "kill", "conditional"] },
    "confidence_weighted": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 5.0,
      "description": "Sum of recalibrated confidence across voting seats backing the winning verdict. Max is roughly n_voting_seats (5 in v2)."
    },
    "confidence_spread": {
      "type": "number",
      "minimum": 0.0,
      "description": "Winning score minus runner-up score. Higher = more decisive."
    },

    "idea_analysis": {
      "type": "string",
      "minLength": 50,
      "maxLength": 1600,
      "description": "Neutral framing of what the idea actually is and the core bet. ≤200 words."
    },
    "verdict_reasoning": {
      "type": "string",
      "minLength": 50,
      "maxLength": 2400,
      "description": "The case for the winning verdict. ≤300 words."
    },
    "vision": {
      "type": "string",
      "minLength": 50,
      "maxLength": 2000,
      "description": "The upside case / what this becomes if it works. ≤250 words."
    },
    "dissent_summary": {
      "type": "string",
      "minLength": 50,
      "maxLength": 2000,
      "description": "The strongest case against the verdict, charitably stated. ≤250 words. Never empty."
    },
    "gtm_analysis": {
      "type": ["string", "null"],
      "minLength": 50,
      "maxLength": 1600,
      "description": "Go-to-market assessment. ≤200 words. A string only when verdict != kill; null/absent when kill."
    },
    "dissent_source": {
      "type": "string",
      "description": "seat_id of the dissenting seat (or the forced-dissent author in unanimous cases)."
    },

    "kill_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["criterion", "owner_to_monitor"],
        "properties": {
          "criterion": { "type": "string", "minLength": 20, "maxLength": 300 },
          "owner_to_monitor": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "additionalProperties": false
      }
    },

    "next_action": {
      "type": "object",
      "required": ["action", "owner", "deadline"],
      "properties": {
        "action": { "type": "string", "minLength": 10, "maxLength": 200 },
        "owner": { "type": "string", "minLength": 1, "maxLength": 100 },
        "deadline": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },

    "signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["seat_id", "verdict", "confidence_raw", "confidence_recalibrated"],
        "properties": {
          "seat_id": { "type": "string" },
          "verdict": { "enum": ["proceed", "kill", "conditional"] },
          "confidence_raw": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "confidence_recalibrated": { "type": "number", "minimum": 0.0, "maximum": 1.5 }
        },
        "additionalProperties": false
      }
    },

    "metadata": {
      "type": "object",
      "required": [
        "persona_hashes",
        "model_ids",
        "seed",
        "wall_clock_seconds",
        "llm_cost_usd",
        "unanimous",
        "forced_dissent_triggered"
      ],
      "properties": {
        "persona_hashes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "model_ids": {
          "type": "object",
          "required": ["seats", "synthesis"],
          "properties": {
            "seats": { "type": "string" },
            "synthesis": { "type": "string" }
          }
        },
        "seed": { "type": "integer" },
        "wall_clock_seconds": { "type": "number", "minimum": 0.0 },
        "llm_cost_usd": { "type": "number", "minimum": 0.0 },
        "unanimous": { "type": "boolean" },
        "forced_dissent_triggered": { "type": "boolean" },
        "references_memo_id": { "type": ["string", "null"], "format": "uuid" },
        "reasoning_overlap_score": { "type": ["number", "null"], "minimum": 0.0, "maximum": 1.0 }
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "description": "gtm_analysis is a non-null string iff the verdict is not kill; null or absent when kill.",
      "if": { "properties": { "verdict": { "const": "kill" } } },
      "then": { "properties": { "gtm_analysis": { "type": "null" } } },
      "else": {
        "required": ["gtm_analysis"],
        "properties": { "gtm_analysis": { "type": "string" } }
      }
    }
  ]
}
